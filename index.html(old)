                <button class="leaderboard-tab" data-p="monthly">Monthly</button>
                <button class="leaderboard-tab" data-p="yearly">Yearly</button>
                <button class="leaderboard-tab" data-p="perfects">👑 Perfect Games</button>
            </div>
            <div class="leaderboard-list" id="lb-list"></div>
            <button class="btn-secondary" onclick="showScreen('home')" style="margin-top:20px">Back to Home</button>
        </div>
