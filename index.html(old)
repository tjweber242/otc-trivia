        function genLB(n,type){
            const names=["BallKnower99","SportsGuru","TriviaMaster","GridironKing","HoopsHead","DiamondDan","IceQueen","TouchdownTom","SluggerSam","NetNinja","CourtVision","DunkMaster"];
            const allTeams=[...TEAMS.nba,...TEAMS.mlb,...TEAMS.nhl];
            return Array(n).fill().map((_,i)=>{
                const team=allTeams[Math.floor(Math.random()*allTeams.length)];
                const perfects=type==='perfects'?Math.max(50-i*2,1):Math.floor(Math.random()*20);
                return{rank:i+1,name:names[i%names.length]+(i>=names.length?Math.floor(i/names.length):''),score:type==='daily'?Math.max(10-Math.floor(i/3),5):type==='perfects'?perfects:Math.floor(Math.random()*500)+(100-i)*10,perfects,team,perfect:type==='daily'&&i<3};
            });
        }
        const LB={daily:genLB(100,'daily'),monthly:genLB(100,'monthly'),yearly:genLB(100,'yearly'),perfects:genLB(100,'perfects')};

        function renderLB(period){
            document.querySelectorAll('.leaderboard-tab').forEach(t=>t.classList.toggle('active',t.dataset.p===period));
            const d=LB[period];const isPerfects=period==='perfects';
            document.getElementById('lb-list').innerHTML=d.slice(0,100).map((p,i)=>{
                const crown=(period!=='daily'&&i===0)||(period==='daily'&&p.perfect);
                const meta=p.perfects>0?`👑 ${p.perfects} perfect game${p.perfects>1?'s':''}`:'';
                const score=period==='daily'?p.score+'/10':isPerfects?p.perfects:p.score;
                return`<div class="leaderboard-item ${i<3?'top-3':''}"><span class="rank ${i===0?'gold':i===1?'silver':i===2?'bronze':''}">${p.rank}</span><div class="lb-avatar" style="background:${p.team.bg};color:${p.team.t}">${p.team.a}</div><div class="lb-info"><div class="lb-name">${p.name}${crown?'<span style="font-size:14px">👑</span>':''}</div>${meta?`<div class="lb-meta">${meta}</div>`:''}</div><div class="lb-score">${score}</div></div>`;
            }).join('');
        }

        function showTeamModal(){
            document.getElementById('team-modal').classList.add('active');
            document.getElementById('league-tabs').innerHTML=Object.keys(TEAMS).map((l,i)=>`<button class="league-tab ${i===0?'active':''}" data-l="${l}">${l.toUpperCase()}</button>`).join('');
            document.querySelectorAll('#league-tabs .league-tab').forEach(t=>t.onclick=()=>renderTeams(t.dataset.l));
            renderTeams('nba');
        }
        function closeTeamModal(){document.getElementById('team-modal').classList.remove('active')}
        function renderTeams(league){
            document.querySelectorAll('#league-tabs .league-tab').forEach(t=>t.classList.toggle('active',t.dataset.l===league));
            document.getElementById('team-grid').innerHTML=TEAMS[league].map(t=>{
                const sel=user.team&&user.team.a===t.a&&user.team.bg===t.bg;
                return`<button class="team-btn ${sel?'selected':''}" onclick="selectTeam('${t.a}','${t.n}','${t.bg}','${t.t}')"><div class="team-circle" style="background:${t.bg};color:${t.t}">${t.a}</div><span class="team-name">${t.n}</span></button>`;
            }).join('');
        }
        function selectTeam(a,n,bg,t){user.team={a,n,bg,t};saveUser();updateUI();renderProfile();closeTeamModal();toast('Team updated!','success')}

        function showAuthModal(m){document.getElementById('auth-modal').classList.add('active');switchAuth(m)}
        function closeAuthModal(){document.getElementById('auth-modal').classList.remove('active')}
        function switchAuth(m){document.getElementById('auth-title').textContent=m==='signup'?'CREATE PROFILE':'WELCOME BACK';document.getElementById('signup-form').style.display=m==='signup'?'flex':'none';document.getElementById('login-form').style.display=m==='login'?'flex':'none'}

        function handleSignup(){
            const u=document.getElementById('signup-user').value,e=document.getElementById('signup-email').value,p=document.getElementById('signup-pass').value;
            if(!u||!e||!p){toast('Fill all fields','error');return}
            user.name=u;user.email=e;user.loggedIn=true;user.joinDate=formatDate();user.lastPlayed=null;
            saveUser();updateUI();closeAuthModal();toast('Profile created!','success');
        }

        function handleLogin(){
            const e=document.getElementById('login-email').value,p=document.getElementById('login-pass').value;
            if(!e||!p){toast('Fill all fields','error');return}
            const saved=localStorage.getItem('otc_'+e);
            if(saved)user=JSON.parse(saved);else{user.email=e;user.name=e.split('@')[0];user.joinDate=formatDate()}
            user.loggedIn=true;saveUser();updateUI();closeAuthModal();toast('Welcome back!','success');
        }

        function socialAuth(p){toast(p+' coming soon!','error')}
        function saveUser(){if(user.email)localStorage.setItem('otc_'+user.email,JSON.stringify(user))}

        document.addEventListener('DOMContentLoaded',()=>{
            document.getElementById('answer-input').addEventListener('keypress',e=>{if(e.key==='Enter')submitAnswer()});
            document.querySelectorAll('.leaderboard-tab').forEach(t=>t.onclick=()=>renderLB(t.dataset.p));
            document.getElementById('auth-modal').onclick=e=>{if(e.target.id==='auth-modal')closeAuthModal()};
            document.getElementById('team-modal').onclick=e=>{if(e.target.id==='team-modal')closeTeamModal()};
            document.getElementById('share-modal').onclick=e=>{if(e.target.id==='share-modal')closeShareModal()};
            document.getElementById('daily-badge').textContent=formatDate();
            updateUI();
            let ht;document.querySelector('.logo').onmousedown=()=>{ht=setTimeout(()=>{user.lastPlayed=null;saveUser();updateUI();toast('Reset!','success')},3000)};
            document.querySelector('.logo').onmouseup=()=>clearTimeout(ht);
        });
    </script>
</body>
</html>
