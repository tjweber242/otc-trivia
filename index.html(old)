        function getDayQuestions(){
            const d=new Date(),seed=d.getFullYear()*10000+d.getMonth()*100+d.getDate();
            const shuffled=[...QUESTIONS].sort((a,b)=>((seed*a.q.length)%100)-((seed*b.q.length)%100));
            const rookie=shuffled.filter(q=>q.diff==='rookie').slice(0,3);
            const veteran=shuffled.filter(q=>q.diff==='veteran').slice(0,4);
            const allpro=shuffled.filter(q=>q.diff==='allpro').slice(0,3);
            return[...rookie,...veteran,...allpro];
        }

        function fuzzy(input,targets){const n=input.toLowerCase().trim();for(const t of targets)if(n===t.toLowerCase())return true;for(const t of targets){const d=lev(n,t.toLowerCase()),m=Math.max(n.length,t.length);if((1-d/m)>=(t.length<=4?.9:.75))return true}return false}
        function lev(a,b){const m=[];for(let i=0;i<=b.length;i++)m[i]=[i];for(let j=0;j<=a.length;j++)m[0][j]=j;for(let i=1;i<=b.length;i++)for(let j=1;j<=a.length;j++)m[i][j]=b[i-1]===a[j-1]?m[i-1][j-1]:Math.min(m[i-1][j-1]+1,m[i][j-1]+1,m[i-1][j]+1);return m[b.length][a.length]}
        function toast(msg,type=''){const t=document.getElementById('toast');t.textContent=msg;t.className='toast '+type;setTimeout(()=>t.classList.add('show'),10);setTimeout(()=>t.classList.remove('show'),3000)}
