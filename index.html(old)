<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#1e40af">
    <title>On The Clock | Do You Know Ball?</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;500;600;700&family=Barlow+Condensed:wght@600;700&display=swap" rel="stylesheet">
    <style>
        :root{--royal-blue:#2563eb;--royal-blue-dark:#1e40af;--royal-blue-light:#3b82f6;--gold:#fbbf24;--gold-light:#fcd34d;--gold-dark:#d97706;--success:#22c55e;--danger:#ef4444;--warning:#f59e0b;--white:#fff}
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:'Barlow',sans-serif;min-height:100vh;color:var(--white);background:radial-gradient(ellipse at 20% 20%,rgba(59,130,246,.4) 0%,transparent 50%),radial-gradient(ellipse at 80% 80%,rgba(30,58,138,.6) 0%,transparent 50%),linear-gradient(180deg,#1e40af 0%,#1e3a8a 50%,#172554 100%);background-attachment:fixed}
        body::before{content:'';position:fixed;top:0;left:0;width:100%;height:100%;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");opacity:.07;pointer-events:none;z-index:0}
        .app-container{position:relative;z-index:1;max-width:480px;margin:0 auto;min-height:100vh;display:flex;flex-direction:column}
        .header{padding:12px 16px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid rgba(255,255,255,.1);background:rgba(30,64,175,.3);backdrop-filter:blur(10px);gap:8px}
        .logo{display:flex;align-items:center;gap:8px;cursor:pointer;transition:transform .2s;flex-shrink:0}
        .logo:hover{transform:scale(1.02)}
        .logo-icon{width:38px;height:38px;background:linear-gradient(145deg,var(--gold-light),var(--gold-dark));border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:16px;color:var(--royal-blue-dark);box-shadow:0 2px 8px rgba(251,191,36,.3)}
        .logo-text{font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:1px}
        .header-actions{display:flex;gap:6px;flex-shrink:0;align-items:center}
        .header-btn{height:34px;border-radius:17px;border:none;background:linear-gradient(145deg,rgba(255,255,255,.15),rgba(255,255,255,.05));color:var(--white);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;padding:0 12px;font-size:12px;font-weight:600;gap:5px}
        .header-btn:hover{background:linear-gradient(145deg,rgba(255,255,255,.25),rgba(255,255,255,.1))}
        .header-btn svg{width:14px;height:14px}
        .header-btn.gold{background:linear-gradient(145deg,var(--gold-light),var(--gold-dark));color:var(--royal-blue-dark)}
        .profile-avatar-btn{width:34px;height:34px;border-radius:50%;border:2px solid var(--gold);cursor:pointer;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:11px;text-shadow:0 2px 4px rgba(0,0,0,.5)}
        .screen{display:none;flex:1;flex-direction:column;padding:20px;padding-bottom:100px;animation:fadeIn .3s}
        .screen.active{display:flex}
        @keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
        .footer{position:fixed;bottom:0;left:0;right:0;background:linear-gradient(180deg,transparent,rgba(23,37,84,.95) 20%);padding:20px;z-index:50}
        .footer-content{max-width:480px;margin:0 auto;text-align:center}
        .social-links{display:flex;justify-content:center;gap:16px;margin-bottom:12px}
        .social-link{width:44px;height:44px;border-radius:50%;border:none;background:linear-gradient(145deg,rgba(255,255,255,.15),rgba(255,255,255,.05));color:var(--white);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s}
        .social-link:hover{background:linear-gradient(145deg,rgba(255,255,255,.25),rgba(255,255,255,.1));transform:scale(1.1)}
        .social-link svg{width:20px;height:20px}
        .footer-text{font-size:12px;color:rgba(255,255,255,.5)}
        .home-hero{text-align:center;padding:30px 0}
        .tagline{font-family:'Bebas Neue',sans-serif;font-size:46px;line-height:1.05;letter-spacing:4px;margin-bottom:12px;text-shadow:0 2px 8px rgba(0,0,0,.3)}
        .subtitle{font-family:'Bebas Neue',sans-serif;font-size:28px;background:linear-gradient(145deg,var(--gold-light),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:4px}
        .daily-badge{display:inline-flex;align-items:center;gap:8px;background:linear-gradient(145deg,rgba(255,255,255,.12),rgba(255,255,255,.05));padding:10px 20px;border-radius:25px;margin-top:20px;font-size:14px;font-weight:600}
        .daily-badge::before{content:'📅'}
        .streak-display{display:flex;justify-content:center;gap:20px;margin-top:16px}
        .streak-item{display:flex;align-items:center;gap:6px;font-size:14px;font-weight:600;color:rgba(255,255,255,.8)}
        .cta-section{padding:24px 0;display:flex;flex-direction:column;gap:12px}
        .btn-primary{width:100%;padding:20px 32px;font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:3px;background:linear-gradient(145deg,var(--gold-light),var(--gold),var(--gold-dark));color:var(--royal-blue-dark);border:none;border-radius:14px;cursor:pointer;transition:all .2s;box-shadow:0 4px 12px rgba(251,191,36,.35),inset 0 2px 0 rgba(255,255,255,.3)}
        .btn-primary:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(251,191,36,.4)}
        .btn-primary:disabled{opacity:.6;cursor:not-allowed;transform:none}
        .btn-secondary{width:100%;padding:16px 24px;font-size:16px;font-weight:600;background:linear-gradient(145deg,rgba(255,255,255,.12),rgba(255,255,255,.05));color:var(--white);border:none;border-radius:12px;cursor:pointer;transition:all .2s}
        .btn-share{display:flex;align-items:center;justify-content:center;gap:10px;padding:14px 24px;background:linear-gradient(145deg,rgba(255,255,255,.95),rgba(255,255,255,.85));color:var(--royal-blue-dark);border:none;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer;transition:all .2s}
        .rules-preview{background:linear-gradient(145deg,rgba(0,0,0,.25),rgba(0,0,0,.15));border-radius:20px;padding:24px;margin-top:20px;border:1px solid rgba(255,255,255,.05)}
        .rules-title{font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;text-transform:uppercase;letter-spacing:2px;margin-bottom:16px;color:var(--gold)}
        .rules-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}
        .rule-item{display:flex;align-items:center;gap:10px;font-size:13px;font-weight:500}
        .rule-icon{width:36px;height:36px;background:linear-gradient(145deg,rgba(255,255,255,.15),rgba(255,255,255,.05));border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
        .login-prompt{background:linear-gradient(145deg,rgba(251,191,36,.15),rgba(251,191,36,.05));border:1px solid rgba(251,191,36,.3);border-radius:16px;padding:20px;text-align:center;margin-top:20px}
        .login-prompt-text{font-size:14px;color:rgba(255,255,255,.8);margin-bottom:12px}
        .login-prompt-btns{display:flex;gap:10px}
        .login-prompt-btns button{flex:1}
        .played-card{background:linear-gradient(145deg,rgba(34,197,94,.15),rgba(34,197,94,.05));border:1px solid rgba(34,197,94,.3);border-radius:16px;padding:20px;text-align:center;margin-bottom:20px}
        .played-card h3{font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:2px;color:var(--success)}
        .played-card .score{font-family:'Bebas Neue',sans-serif;font-size:48px;color:var(--gold);margin:12px 0}
        .game-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px}
        .question-counter{font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:600;text-transform:uppercase;letter-spacing:2px;color:rgba(255,255,255,.7)}
        .difficulty-badge{padding:8px 14px;border-radius:20px;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:1px}
        .difficulty-rookie{background:linear-gradient(145deg,#4ade80,#22c55e);color:#052e16}
        .difficulty-veteran{background:linear-gradient(145deg,#fbbf24,#f59e0b);color:#451a03}
        .difficulty-allpro{background:linear-gradient(145deg,#f87171,#ef4444);color:#fff}
        .timer-container{display:flex;flex-direction:column;align-items:center;margin-bottom:24px}
        .timer-ring{width:110px;height:110px;position:relative}
        .timer-ring svg{transform:rotate(-90deg)}
        .timer-ring circle{fill:none;stroke-width:8}
        .timer-ring .bg{stroke:rgba(255,255,255,.1)}
        .timer-ring .progress{stroke:var(--success);stroke-linecap:round;transition:stroke-dashoffset .1s linear,stroke .3s}
        .timer-text{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Bebas Neue',sans-serif;font-size:40px;letter-spacing:2px}
        .question-card{background:linear-gradient(145deg,rgba(255,255,255,.1),rgba(255,255,255,.03));border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:28px;margin-bottom:24px}
        .question-text{font-size:20px;font-weight:600;line-height:1.4;text-align:center}
        .answer-input{width:100%;padding:18px 22px;font-family:'Barlow',sans-serif;font-size:18px;font-weight:500;background:linear-gradient(145deg,rgba(255,255,255,.12),rgba(255,255,255,.06));border:2px solid rgba(255,255,255,.15);border-radius:14px;color:var(--white);outline:none;transition:all .2s}
        .answer-input::placeholder{color:rgba(255,255,255,.4)}
        .answer-input:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(251,191,36,.2)}
        .answer-input.correct{border-color:var(--success);background:rgba(34,197,94,.2)}
        .answer-input.incorrect{border-color:var(--danger);background:rgba(239,68,68,.2)}
        .submit-btn{width:100%;padding:18px;margin-top:12px;font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:2px;background:linear-gradient(145deg,var(--gold-light),var(--gold-dark));color:var(--royal-blue-dark);border:none;border-radius:14px;cursor:pointer;transition:all .2s}
        .submit-btn:disabled{opacity:.5;cursor:not-allowed}
        .lifeline-section{display:flex;justify-content:center;gap:12px;margin-bottom:20px}
        .lifeline-btn{display:flex;align-items:center;gap:8px;padding:12px 18px;background:linear-gradient(145deg,rgba(255,255,255,.12),rgba(255,255,255,.05));border:none;border-radius:25px;color:var(--white);font-size:14px;font-weight:600;cursor:pointer}
        .lifeline-btn:disabled{opacity:.3;cursor:not-allowed}
        .lifeline-btn .count{background:linear-gradient(145deg,var(--gold-light),var(--gold-dark));color:var(--royal-blue-dark);width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700}
        .mc-container{display:none;flex-direction:column;gap:10px;margin-top:16px}
        .mc-container.active{display:flex}
        .choice-btn{padding:16px 20px;background:linear-gradient(145deg,rgba(255,255,255,.1),rgba(255,255,255,.03));border:2px solid rgba(255,255,255,.15);border-radius:12px;color:var(--white);font-size:16px;font-weight:500;cursor:pointer;text-align:left;transition:all .2s}
        .choice-btn.correct{border-color:var(--success);background:rgba(34,197,94,.3)}
        .choice-btn.incorrect{border-color:var(--danger);background:rgba(239,68,68,.3)}
        .score-display{display:flex;justify-content:center;gap:40px;background:linear-gradient(145deg,rgba(0,0,0,.25),rgba(0,0,0,.15));border-radius:12px;padding:14px 20px;margin-top:auto}
        .score-item{text-align:center}
        .score-label{font-size:11px;text-transform:uppercase;letter-spacing:1px;color:rgba(255,255,255,.6);margin-bottom:4px}
        .score-value{font-family:'Bebas Neue',sans-serif;font-size:26px}
        .feedback-overlay{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.85);z-index:100;justify-content:center;align-items:center}
        .feedback-overlay.active{display:flex}
        .feedback-content{text-align:center;padding:40px}
        .feedback-icon{font-size:72px;margin-bottom:16px;animation:bounceIn .4s}
        @keyframes bounceIn{0%{transform:scale(0)}50%{transform:scale(1.2)}100%{transform:scale(1)}}
        .feedback-text{font-family:'Bebas Neue',sans-serif;font-size:42px;letter-spacing:4px;margin-bottom:8px}
        .feedback-answer{font-size:18px;color:rgba(255,255,255,.7)}
        .results-header{text-align:center;padding:30px 0}
        .results-title{font-family:'Bebas Neue',sans-serif;font-size:40px;letter-spacing:4px;margin-bottom:8px}
        .results-date{font-size:14px;color:rgba(255,255,255,.6)}
        .final-score-card{background:linear-gradient(145deg,var(--gold-light),var(--gold),var(--gold-dark));border-radius:24px;padding:32px;text-align:center;color:var(--royal-blue-dark);margin-bottom:24px;box-shadow:0 6px 25px rgba(251,191,36,.35)}
        .final-score-label{font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:2px;opacity:.7}
        .final-score-value{font-family:'Bebas Neue',sans-serif;font-size:80px;line-height:1;margin:8px 0}
        .final-score-subtitle{font-size:18px;font-weight:600;opacity:.8}
        .perfect-badge{display:none;align-items:center;gap:8px;background:rgba(0,0,0,.15);padding:10px 20px;border-radius:25px;margin-top:16px;font-weight:700}
        .question-recap{background:linear-gradient(145deg,rgba(0,0,0,.25),rgba(0,0,0,.15));border-radius:20px;padding:20px;margin-bottom:24px}
        .recap-title{font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:700;text-transform:uppercase;letter-spacing:2px;margin-bottom:16px;color:var(--gold)}
        .recap-list{display:flex;flex-direction:column;gap:8px}
        .recap-item{display:flex;align-items:center;gap:12px;padding:12px 14px;background:linear-gradient(145deg,rgba(255,255,255,.08),rgba(255,255,255,.02));border-radius:10px;font-size:14px}
        .recap-icon{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0}
        .recap-icon.correct{background:linear-gradient(145deg,#4ade80,#22c55e)}
        .recap-icon.incorrect{background:linear-gradient(145deg,#f87171,#ef4444)}
        .recap-question{flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
        .next-game-timer{text-align:center;margin-top:24px;padding:18px;background:linear-gradient(145deg,rgba(255,255,255,.08),rgba(255,255,255,.02));border-radius:14px}
        .next-game-label{font-size:13px;color:rgba(255,255,255,.6);margin-bottom:8px}
        .next-game-time{font-family:'Bebas Neue',sans-serif;font-size:36px;letter-spacing:4px}
        .profile-header{text-align:center;padding:30px 0}
        .avatar-wrapper{position:relative;display:inline-block;margin-bottom:16px}
        .avatar-large{width:110px;height:110px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:36px;border:4px solid var(--gold);text-shadow:0 2px 4px rgba(0,0,0,.5),0 0 2px rgba(0,0,0,.8)}
        .avatar-change-btn{position:absolute;bottom:0;right:0;width:36px;height:36px;background:linear-gradient(145deg,var(--gold-light),var(--gold-dark));border:3px solid var(--royal-blue-dark);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer}
        .avatar-change-btn svg{width:16px;height:16px;color:var(--royal-blue-dark)}
        .profile-name{font-family:'Bebas Neue',sans-serif;font-size:32px;letter-spacing:3px}
        .profile-joined{font-size:13px;color:rgba(255,255,255,.6);margin-top:4px}
        .profile-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin:30px 0}
        .stat-card{background:linear-gradient(145deg,rgba(255,255,255,.12),rgba(255,255,255,.04));border-radius:14px;padding:16px 8px;text-align:center}
        .stat-value{font-family:'Bebas Neue',sans-serif;font-size:28px;background:linear-gradient(145deg,var(--gold-light),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
        .stat-label{font-size:9px;text-transform:uppercase;letter-spacing:1px;color:rgba(255,255,255,.6);margin-top:4px}
        .achievements-section{background:linear-gradient(145deg,rgba(0,0,0,.25),rgba(0,0,0,.15));border-radius:20px;padding:24px;margin-bottom:20px}
        .achievements-title{font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:700;text-transform:uppercase;letter-spacing:2px;margin-bottom:16px;color:var(--gold)}
        .achievement-item{display:flex;align-items:center;gap:12px;padding:12px;background:linear-gradient(145deg,rgba(255,255,255,.08),rgba(255,255,255,.02));border-radius:12px;margin-bottom:8px}
        .achievement-item.unlocked{background:linear-gradient(145deg,rgba(251,191,36,.15),rgba(251,191,36,.05));border:1px solid rgba(251,191,36,.3)}
        .achievement-item.locked{opacity:.5}
        .achievement-icon{font-size:24px}
        .achievement-info{flex:1}
        .achievement-name{font-weight:600;font-size:14px}
        .achievement-desc{font-size:12px;color:rgba(255,255,255,.6)}
        .leaderboard-tabs{display:flex;background:linear-gradient(145deg,rgba(0,0,0,.3),rgba(0,0,0,.2));border-radius:14px;padding:4px;margin-bottom:20px;overflow-x:auto}
        .leaderboard-tab{flex:1;padding:12px 6px;background:transparent;border:none;border-radius:10px;color:rgba(255,255,255,.6);font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;cursor:pointer;white-space:nowrap}
        .leaderboard-tab.active{background:linear-gradient(145deg,var(--royal-blue-light),var(--royal-blue));color:var(--white)}
        .leaderboard-list{display:flex;flex-direction:column;gap:8px;max-height:55vh;overflow-y:auto}
        .leaderboard-item{display:flex;align-items:center;gap:12px;padding:12px 14px;background:linear-gradient(145deg,rgba(255,255,255,.08),rgba(255,255,255,.02));border-radius:12px}
        .leaderboard-item.top-3{background:linear-gradient(145deg,rgba(251,191,36,.15),rgba(251,191,36,.05));border:1px solid rgba(251,191,36,.3)}
        .rank{width:28px;font-family:'Bebas Neue',sans-serif;font-size:20px;text-align:center}
        .rank.gold{color:#fbbf24}
        .rank.silver{color:#d1d5db}
        .rank.bronze{color:#cd7f32}
        .lb-avatar{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:12px;text-shadow:0 2px 4px rgba(0,0,0,.5)}
        .lb-info{flex:1;min-width:0}
        .lb-name{font-weight:600;font-size:14px;display:flex;align-items:center;gap:6px}
        .lb-meta{font-size:11px;color:rgba(255,255,255,.5)}
        .lb-score{font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--gold)}
        .modal-overlay{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.85);z-index:200;justify-content:center;align-items:flex-end}
        .modal-overlay.active{display:flex}
        .modal-content{width:100%;max-width:480px;background:linear-gradient(180deg,#1e40af 0%,#1e3a8a 100%);border-radius:24px 24px 0 0;padding:32px 24px;animation:slideUp .3s}
        @keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
        .modal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px}
        .modal-title{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:2px}
        .modal-close{width:40px;height:40px;border-radius:50%;border:none;background:linear-gradient(145deg,rgba(255,255,255,.15),rgba(255,255,255,.05));color:var(--white);font-size:24px;cursor:pointer;display:flex;align-items:center;justify-content:center}
        .auth-form{display:flex;flex-direction:column;gap:16px}
        .form-group{display:flex;flex-direction:column;gap:8px}
        .form-label{font-size:13px;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:rgba(255,255,255,.7)}
        .form-input{padding:16px 18px;background:linear-gradient(145deg,rgba(255,255,255,.12),rgba(255,255,255,.06));border:2px solid rgba(255,255,255,.15);border-radius:12px;color:var(--white);font-size:16px;outline:none}
        .form-input:focus{border-color:var(--gold)}
        .auth-divider{display:flex;align-items:center;gap:16px;margin:8px 0;color:rgba(255,255,255,.4);font-size:13px}
        .auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:rgba(255,255,255,.2)}
        .social-auth{display:flex;gap:12px}
        .social-auth-btn{flex:1;padding:16px;display:flex;align-items:center;justify-content:center;gap:10px;background:#fff;border:none;border-radius:12px;font-size:14px;font-weight:600;color:#1f2937;cursor:pointer}
        .auth-switch{text-align:center;margin-top:16px;font-size:14px;color:rgba(255,255,255,.6)}
        .auth-switch a{color:var(--gold);text-decoration:none;font-weight:600}
        .team-modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.85);z-index:200;justify-content:center;align-items:flex-end}
        .team-modal.active{display:flex}
        .team-modal-content{width:100%;max-width:480px;max-height:85vh;background:linear-gradient(180deg,#1e40af 0%,#1e3a8a 100%);border-radius:24px 24px 0 0;padding:24px;overflow-y:auto;animation:slideUp .3s}
        .league-tabs{display:flex;gap:6px;margin-bottom:16px;overflow-x:auto;padding-bottom:8px;flex-wrap:wrap}
        .league-tab{padding:8px 14px;background:linear-gradient(145deg,rgba(255,255,255,.1),rgba(255,255,255,.03));border:none;border-radius:20px;color:var(--white);font-size:12px;font-weight:600;cursor:pointer;white-space:nowrap}
        .league-tab.active{background:linear-gradient(145deg,var(--gold-light),var(--gold-dark));color:var(--royal-blue-dark)}
        .team-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
        .team-btn{display:flex;flex-direction:column;align-items:center;gap:4px;padding:8px 4px;background:linear-gradient(145deg,rgba(255,255,255,.08),rgba(255,255,255,.02));border:2px solid transparent;border-radius:12px;cursor:pointer}
        .team-btn.selected{border-color:var(--gold)}
        .team-circle{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:12px;text-shadow:0 2px 4px rgba(0,0,0,.5)}
        .team-name{font-size:9px;color:rgba(255,255,255,.7);text-align:center;line-height:1.1}
        .share-modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.9);z-index:250;justify-content:center;align-items:center;padding:20px}
        .share-modal.active{display:flex}
        .share-preview{width:100%;max-width:340px;background:linear-gradient(180deg,#1e40af 0%,#1e3a8a 100%);border-radius:20px;padding:24px;text-align:center;animation:scaleIn .3s}
        @keyframes scaleIn{from{transform:scale(.9);opacity:0}to{transform:scale(1);opacity:1}}
        .share-header{display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:20px}
        .share-logo{width:36px;height:36px;background:linear-gradient(145deg,var(--gold-light),var(--gold-dark));border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:14px;color:var(--royal-blue-dark)}
        .share-title{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:2px}
        .share-score-box{background:linear-gradient(145deg,var(--gold-light),var(--gold-dark));border-radius:16px;padding:20px;margin-bottom:16px;color:var(--royal-blue-dark)}
        .share-score-value{font-family:'Bebas Neue',sans-serif;font-size:48px}
        .share-score-label{font-size:12px;font-weight:700;text-transform:uppercase}
        .share-emoji{display:flex;justify-content:center;gap:4px;margin-bottom:16px;font-size:24px}
        .share-tagline{font-family:'Bebas Neue',sans-serif;font-size:16px;color:var(--gold);letter-spacing:2px;margin-bottom:20px}
        .share-buttons{display:flex;flex-direction:column;gap:10px}
        .share-close{margin-top:16px;padding:12px;background:transparent;border:none;color:rgba(255,255,255,.6);font-size:14px;cursor:pointer}
        .toast{position:fixed;top:20px;left:50%;transform:translateX(-50%) translateY(-100px);background:#1f2937;color:var(--white);padding:14px 28px;border-radius:12px;font-size:14px;font-weight:600;z-index:300;transition:transform .3s}
        .toast.show{transform:translateX(-50%) translateY(0)}
        .toast.success{background:#22c55e}
        .toast.error{background:#ef4444}
        @media(max-width:400px){.tagline{font-size:38px}.subtitle{font-size:22px}.rules-grid{grid-template-columns:1fr}.team-grid{grid-template-columns:repeat(3,1fr)}.profile-stats{grid-template-columns:repeat(2,1fr)}.header-btn{padding:0 8px;font-size:10px}.logo-text{display:none}}
    </style>
</head>
<body>
    <div class="app-container">
        <header class="header">
