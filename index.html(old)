            document.getElementById('recap-list').innerHTML=game.results.map((r,i)=>`<div class="recap-item"><span class="recap-icon ${r.correct?'correct':'incorrect'}">${r.correct?'✓':'✗'}</span><span class="recap-question">Q${i+1}: ${r.q.substring(0,35)}...</span></div>`).join('');
