        function loadQ(){
            const q=game.dayQuestions[game.qNum];
            document.getElementById('q-counter').textContent=`Question ${game.qNum+1} of 10`;
            document.getElementById('q-text').textContent=q.q;
            const b=document.getElementById('diff-badge');b.className='difficulty-badge difficulty-'+q.diff;b.textContent=q.diff==='allpro'?'All-Pro':q.diff.charAt(0).toUpperCase()+q.diff.slice(1);
            const inp=document.getElementById('answer-input');inp.value='';inp.className='answer-input';inp.disabled=false;inp.focus();
            game.mcMode=false;document.getElementById('type-container').style.display='block';document.getElementById('mc-container').classList.remove('active');
            document.getElementById('lifeline-btn').disabled=game.lifelines===0;document.getElementById('lifeline-count').textContent=game.lifelines;
            updateGameScore();game.answered=false;game.time=25;startTimer();
        }

        function startTimer(){
            clearInterval(game.timer);const p=document.getElementById('timer-progress'),txt=document.getElementById('timer-text'),c=2*Math.PI*46;
            p.style.strokeDasharray=c;p.style.strokeDashoffset=0;
            game.timer=setInterval(()=>{
                if(game.answered){clearInterval(game.timer);return}
                game.time-=0.1;if(game.time<=0){game.time=0;clearInterval(game.timer);timeout()}
                txt.textContent=Math.ceil(game.time);
                p.style.strokeDashoffset=(1-game.time/25)*c;
                p.style.stroke=game.time<=5?'var(--danger)':game.time<=10?'var(--warning)':'var(--success)';
            },100);
        }

        function submitAnswer(){
            if(game.answered)return;
            const a=document.getElementById('answer-input').value.trim();
            if(!a){toast('Enter an answer!','error');return}
            process(fuzzy(a,game.dayQuestions[game.qNum].accept),a);
        }

        function process(correct,answer){
            game.answered=true;clearInterval(game.timer);
            const q=game.dayQuestions[game.qNum];
            if(correct){game.correct++;game.streak++}else{game.streak=0}
            game.results.push({q:q.q,correct,user:answer,ans:q.a});
            feedback(correct,q.a);
            const inp=document.getElementById('answer-input');inp.disabled=true;inp.classList.add(correct?'correct':'incorrect');
        }

        function timeout(){const q=game.dayQuestions[game.qNum];game.results.push({q:q.q,correct:false,user:'(Time)',ans:q.a});game.streak=0;feedback(false,q.a,true)}

        function feedback(correct,answer,timeout=false){
            const o=document.getElementById('feedback-overlay'),ic=document.getElementById('fb-icon'),tx=document.getElementById('fb-text'),an=document.getElementById('fb-answer');
            if(correct){ic.textContent='✓';ic.style.color='var(--success)';tx.textContent='CORRECT!';an.textContent=''}
            else{ic.textContent=timeout?'⏱️':'✗';ic.style.color='var(--danger)';tx.textContent=timeout?"TIME'S UP!":'INCORRECT';an.textContent='Answer: '+answer}
            o.classList.add('active');
            setTimeout(()=>{o.classList.remove('active');an.textContent='';game.qNum++;game.qNum>=10?endGame():loadQ()},1500);
        }

        function useLifeline(){
            if(game.lifelines===0||game.mcMode)return;
            game.lifelines--;game.mcMode=true;
            document.getElementById('lifeline-btn').disabled=true;document.getElementById('lifeline-count').textContent=game.lifelines;
            document.getElementById('type-container').style.display='none';document.getElementById('mc-container').classList.add('active');
            const q=game.dayQuestions[game.qNum];
            document.querySelectorAll('.choice-btn').forEach((b,i)=>{b.textContent=q.choices[i];b.className='choice-btn';b.disabled=false;b.onclick=()=>selectChoice(i)});
        }

        function selectChoice(i){
            if(game.answered)return;
            const q=game.dayQuestions[game.qNum],correct=q.choices[i]===q.a;
            document.querySelectorAll('.choice-btn').forEach((b,j)=>{b.disabled=true;if(q.choices[j]===q.a)b.classList.add('correct');else if(j===i&&!correct)b.classList.add('incorrect')});
            process(correct,q.choices[i]);
        }

        function updateGameScore(){document.getElementById('game-score').textContent=game.correct+'/'+game.qNum;document.getElementById('game-streak').textContent=game.streak}

        function endGame(){
            const today=new Date().toDateString();
            user.lastPlayed=today;user.lastScore=game.correct;user.gamesPlayed++;
