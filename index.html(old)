                    <div class="rule-item"><span class="rule-icon">⏱️</span><span>25 Sec Per Question</span></div>
                    <div class="rule-item"><span class="rule-icon">🎯</span><span>Type Your Answers</span></div>
                    <div class="rule-item"><span class="rule-icon">🆘</span><span>2 Multiple Choice Lifelines</span></div>
