                <div class="final-score-value" id="final-score">0/10</div>
                <div class="final-score-subtitle" id="score-msg">Keep practicing!</div>
                <div class="perfect-badge" id="perfect-badge">👑 PERFECT GAME!</div>
            </div>
            <div class="question-recap">
                <h3 class="recap-title">Question Recap</h3>
                <div class="recap-list" id="recap-list"></div>
            </div>
            <div class="share-section">
                <button class="btn-primary" onclick="showShareModal()">SHARE MY SCORE</button>
                <button class="btn-share" onclick="shareGame()">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
