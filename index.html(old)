                <div class="next-game-label">Next game in</div>
                <div class="next-game-time" id="next-time">--:--:--</div>
            </div>
            <button class="btn-secondary" onclick="showScreen('home')" style="margin-top:20px">Back to Home</button>
        </div>

        <div class="screen" id="profile-screen">
            <div class="profile-header">
                <div class="avatar-wrapper">
                    <div class="avatar-large" id="profile-avatar" style="background:#2563eb">?</div>
                    <button class="avatar-change-btn" onclick="showTeamModal()">
                        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                    </button>
                </div>
                <h2 class="profile-name" id="profile-name">Guest Player</h2>
                <p class="profile-joined" id="profile-joined">Playing since today</p>
            </div>
            <div class="profile-stats">
                <div class="stat-card"><div class="stat-value" id="stat-games">0</div><div class="stat-label">Games</div></div>
                <div class="stat-card"><div class="stat-value" id="stat-best">0</div><div class="stat-label">Best</div></div>
                <div class="stat-card"><div class="stat-value" id="stat-perfects">0</div><div class="stat-label">Perfect Games</div></div>
                <div class="stat-card"><div class="stat-value" id="stat-streak">0</div><div class="stat-label">Day Streak</div></div>
            </div>
            <div class="achievements-section" id="achievements"></div>
            <button class="btn-secondary" onclick="showScreen('home')">Back to Home</button>
        </div>

        <div class="screen" id="leaderboard-screen">
            <h2 style="font-family:'Bebas Neue';font-size:32px;letter-spacing:3px;text-align:center;margin-bottom:20px">LEADERBOARD</h2>
            <div class="leaderboard-tabs">
